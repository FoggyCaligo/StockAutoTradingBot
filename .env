APP_ENV=paper

KIS_APP_KEY=
KIS_APP_SECRET=
KIS_HTS_ID=

KIS_ACCOUNT_NO=12345678
KIS_ACCOUNT_PRODUCT_CODE=01

# 현재 공식 문서상 운영 REST
KIS_REST_BASE_URL=https://openapi.koreainvestment.com:9443

# 웹소켓 URL은 문서/환경에 따라 바뀔 수 있으니 직접 명시
KIS_WS_BASE_URL=

# 토큰/웹소켓 승인키 관련 경로
KIS_TOKEN_PATH=/oauth2/tokenP
KIS_WS_APPROVAL_PATH=

# 주문/시세/호가 경로
KIS_INQUIRE_PRICE_PATH=/uapi/domestic-stock/v1/quotations/inquire-price
KIS_INQUIRE_ORDERBOOK_PATH=/uapi/domestic-stock/v1/quotations/inquire-asking-price-exp-ccn
KIS_ORDER_CASH_PATH=/uapi/domestic-stock/v1/trading/order-cash
KIS_HASHKEY_PATH=/uapi/hashkey

# TR ID는 계좌유형/실전·모의에 따라 다를 수 있으니 분리
KIS_TR_PRICE=
KIS_TR_ORDERBOOK=
KIS_TR_BUY=
KIS_TR_SELL=
KIS_TR_BALANCE=

# 웹소켓 구독용 TR ID / 고객타입 / 시장코드도 분리
KIS_WS_TR_ORDERBOOK=
KIS_WS_TR_TRADE=
KIS_CUSTTYPE=P

# 전략 파라미터
TOP_K=3
ENTRY_THRESHOLD=0.008
MAX_SPREAD_RATIO=0.0015
STOP_LOSS_RATIO=0.005
TAKE_PROFIT_RATIO=0.010
MAX_HOLD_SECONDS=300
MAX_DAILY_LOSS=150000